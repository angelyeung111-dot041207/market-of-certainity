      <td>$${m.sellVol.toFixed(0)}</td>
      <td><div class="bar-bg"><div class="bar-fill" style="width:${fillW}%;background:${barColor};"></div></div></td>
      <td>${suspBadge}</td>
      <td style="font-size:10px;font-family:var(--mono);color:var(--muted);">${m.id.slice(0,20)}…</td>
    </tr>`;
  }).join('');
}

render();
</script>
</body>
</html>
