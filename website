<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Market of Certainty</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --ink: #1a1714; --paper: #f5f1e8; --muted: #7a7469;
    --accent: #c0392b; --accent2: #2c3e50; --border: rgba(26,23,20,0.12);
    --serif: 'Playfair Display', Georgia, serif;
    --mono: 'DM Mono', monospace; --sans: 'DM Sans', sans-serif;
    --color-background-primary: #f5f1e8;
    --color-background-secondary: rgba(26,23,20,0.05);
    --color-text-primary: #1a1714;
    --color-text-secondary: #7a7469;
    --color-border-secondary: rgba(26,23,20,0.2);
    --color-border-tertiary: rgba(26,23,20,0.1);
    --border-radius-md: 6px;
    --font-mono: 'DM Mono', monospace;
  }
  html { scroll-behavior: smooth; }
  body { font-family: var(--sans); background: var(--paper); color: var(--ink); font-size: 17px; line-height: 1.75; overflow-x: hidden; }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: rgba(245,241,232,0.94); backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
    padding: 0 2.5rem; height: 56px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .nav-logo { font-family: var(--mono); font-size: 11px; letter-spacing: 0.12em; color: var(--muted); text-transform: uppercase; }
  .nav-links { display: flex; gap: 1.5rem; list-style: none; }
  .nav-links a { font-family: var(--mono); font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); text-decoration: none; transition: color 0.2s; }
  .nav-links a:hover { color: var(--accent); }

  /* HERO */
  .hero {
    min-height: 100vh; display: flex; flex-direction: column; justify-content: flex-end;
    padding: 7rem 2.5rem 4rem; position: relative; border-bottom: 1px solid var(--border); overflow: hidden;
  }
  .hero-bg-text {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
    font-family: var(--serif); font-size: clamp(6rem, 15vw, 14rem); font-weight: 700;
    color: rgba(26,23,20,0.04); white-space: nowrap; pointer-events: none; user-select: none; letter-spacing: -0.03em;
  }
  .hero-tag { font-family: var(--mono); font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--accent); margin-bottom: 1.5rem; }
  .hero h1 { font-family: var(--serif); font-size: clamp(2.8rem, 7vw, 5.5rem); font-weight: 700; line-height: 1.05; letter-spacing: -0.02em; max-width: 900px; margin-bottom: 1.5rem; }
  .hero h1 em { font-style: italic; color: var(--accent); }
  .hero-sub { font-size: 1.05rem; color: var(--muted); max-width: 520px; margin-bottom: 3rem; font-weight: 300; }
  .hero-meta { display: flex; gap: 3rem; padding-top: 2rem; border-top: 1px solid var(--border); flex-wrap: wrap; }
  .hero-meta-label { font-family: var(--mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); display: block; margin-bottom: 0.2rem; }
  .hero-meta-val { font-size: 0.95rem; font-weight: 500; }
  .scroll-hint { position: absolute; bottom: 2rem; right: 2.5rem; font-family: var(--mono); font-size: 10px; letter-spacing: 0.1em; color: var(--muted); text-transform: uppercase; writing-mode: vertical-rl; display: flex; align-items: center; gap: 8px; }
  .scroll-hint::before { content: ''; width: 1px; height: 40px; background: var(--border); display: block; }

  /* LAYOUT */
  .w-section { padding: 5rem 2.5rem; border-bottom: 1px solid var(--border); }
  .w-inner { max-width: 1100px; margin: 0 auto; }

  .section-label { font-family: var(--mono); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); margin-bottom: 1rem; display: flex; align-items: center; gap: 0.75rem; }
  .section-label::after { content: ''; flex: 1; max-width: 60px; height: 1px; background: var(--accent); opacity: 0.4; }
  h2.section-title { font-family: var(--serif); font-size: clamp(1.9rem, 4vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.01em; margin-bottom: 1.5rem; }

  .intro-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; margin-top: 3rem; }
  .intro-lead { font-family: var(--serif); font-size: 1.25rem; line-height: 1.6; }
  .intro-body { font-size: 0.95rem; color: var(--muted); line-height: 1.8; }
  .intro-body p + p { margin-top: 1rem; }

  .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; border: 1px solid var(--border); margin: 3rem 0; }
  .stat-card { padding: 2rem 1.5rem; background: var(--paper); border-right: 1px solid var(--border); }
  .stat-card:last-child { border-right: none; }
  .stat-number { font-family: var(--serif); font-size: 3rem; font-weight: 700; line-height: 1; color: var(--accent); margin-bottom: 0.5rem; }
  .stat-label { font-family: var(--mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); }

  /* PULL QUOTE */
  .pull-quote { padding: 4rem 2.5rem; background: var(--accent2); color: #f5f1e8; text-align: center; border-bottom: 1px solid var(--border); }
  .pull-quote blockquote { font-family: var(--serif); font-size: clamp(1.4rem, 3vw, 2.2rem); font-style: italic; line-height: 1.4; max-width: 760px; margin: 0 auto 1rem; }
  .pull-quote cite { font-family: var(--mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.5; font-style: normal; }

  /* VIZ */
  .viz-block { margin-top: 2.5rem; }
  .viz-img-wrap { width: 100%; border-radius: 4px; overflow: hidden; border: 1px solid var(--border); background: #faf7f0; }
  .viz-img-wrap img { width: 100%; height: auto; display: block; }
  .viz-caption { margin-top: 1.25rem; font-size: 0.85rem; color: var(--muted); font-style: italic; border-left: 2px solid var(--accent); padding-left: 1rem; line-height: 1.6; }

  /* INTERACTIVE EMBED */
  .interactive-embed-wrap {
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    background: var(--paper);
  }
  .interactive-embed-header {
    padding: 0.75rem 1.25rem;
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; gap: 0.75rem;
    background: rgba(26,23,20,0.03);
  }
  .interactive-badge {
    font-family: var(--mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase;
    background: var(--accent); color: #fff;
    padding: 3px 10px; border-radius: 20px;
  }
  .interactive-title {
    font-family: var(--mono); font-size: 11px; color: var(--muted); letter-spacing: 0.05em;
  }
  .interactive-body { padding: 1.5rem 1.25rem; }

  /* 100% BUY CLUB WIDGET STYLES */
  .buyclub * { box-sizing: border-box; }
  .buyclub .header { padding: 0.5rem 0 0.5rem; }
  .buyclub .kpi-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 1.25rem; }
  .buyclub .kpi { background: var(--color-background-secondary); border-radius: var(--border-radius-md); padding: 0.75rem 1rem; }
  .buyclub .kpi-label { font-size: 12px; color: var(--color-text-secondary); margin: 0 0 4px; font-family: var(--mono); letter-spacing: 0.05em; }
  .buyclub .kpi-value { font-size: 22px; font-weight: 500; color: var(--color-text-primary); margin: 0; font-family: var(--serif); }
  .buyclub .controls { display: flex; align-items: center; gap: 12px; margin-bottom: 1rem; flex-wrap: wrap; }
  .buyclub .controls label { font-size: 13px; color: var(--color-text-secondary); font-family: var(--mono); }
  .buyclub .controls select { font-size: 13px; padding: 4px 8px; border-radius: var(--border-radius-md); border: 0.5px solid var(--color-border-secondary); background: var(--color-background-primary); color: var(--color-text-primary); }
  .buyclub .controls input[type=range] { width: 120px; }
  .buyclub .controls span { font-size: 13px; font-weight: 500; min-width: 28px; color: var(--color-text-primary); font-family: var(--mono); }
  .buyclub .chart-wrap { position: relative; width: 100%; }
  .buyclub .legend { display: flex; gap: 16px; margin-bottom: 8px; flex-wrap: wrap; }
  .buyclub .legend-item { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--color-text-secondary); font-family: var(--mono); }
  .buyclub .legend-dot { width: 10px; height: 10px; border-radius: 2px; }
  .buyclub .table-wrap { margin-top: 1.5rem; overflow-x: auto; }
  .buyclub table { width: 100%; border-collapse: collapse; font-size: 13px; table-layout: fixed; }
  .buyclub th { text-align: left; padding: 6px 10px; font-weight: 500; font-size: 12px; color: var(--color-text-secondary); border-bottom: 0.5px solid var(--color-border-tertiary); font-family: var(--mono); }
  .buyclub td { padding: 7px 10px; border-bottom: 0.5px solid var(--color-border-tertiary); color: var(--color-text-primary); word-break: break-all; }
  .buyclub tr:last-child td { border-bottom: none; }
  .buyclub .badge { display: inline-block; padding: 2px 7px; border-radius: 99px; font-size: 11px; font-weight: 500; }
  .buyclub .badge-red { background: #FCEBEB; color: #A32D2D; }
  .buyclub .badge-amber { background: #FAEEDA; color: #854F0B; }
  .buyclub .badge-green { background: #EAF3DE; color: #3B6D11; }
  .buyclub .bar-bg { background: var(--color-border-tertiary); border-radius: 3px; height: 8px; width: 100%; }
  .buyclub .bar-fill { height: 8px; border-radius: 3px; transition: width 0.3s; }

  /* CASES */
  .cases-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; margin-top: 3rem; border: 1px solid var(--border); }
  .case-card { padding: 2rem 1.75rem; background: var(--paper); border-right: 1px solid var(--border); transition: background 0.2s; }
  .case-card:last-child { border-right: none; }
  .case-card:hover { background: rgba(192,57,43,0.04); }
  .case-tag { font-family: var(--mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.75rem; }
  .case-title { font-family: var(--serif); font-size: 1.2rem; font-weight: 700; margin-bottom: 0.75rem; line-height: 1.3; }
  .case-body { font-size: 0.88rem; color: var(--muted); line-height: 1.7; }

  /* JUSTICE */
  .justice-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-top: 3rem; }
  .justice-item { padding: 1.75rem; border: 1px solid var(--border); border-left: 3px solid var(--accent2); border-radius: 2px; }
  .justice-item h3 { font-family: var(--serif); font-size: 1.1rem; margin-bottom: 0.6rem; font-weight: 700; }
  .justice-item p { font-size: 0.9rem; color: var(--muted); line-height: 1.7; }

  /* METHODOLOGY */
  .method-step { display: grid; grid-template-columns: 60px 1fr; gap: 1.5rem; padding: 2rem 0; border-top: 1px solid var(--border); align-items: start; }
  .method-num { font-family: var(--serif); font-size: 2.5rem; font-weight: 700; color: rgba(26,23,20,0.1); line-height: 1; }
  .method-content h3 { font-family: var(--serif); font-size: 1.05rem; font-weight: 700; margin-bottom: 0.4rem; }
  .method-content p { font-size: 0.88rem; color: var(--muted); line-height: 1.7; }
  .method-content code { display: inline-block; font-family: var(--mono); font-size: 0.78rem; background: rgba(26,23,20,0.06); padding: 2px 8px; border-radius: 3px; margin-top: 0.5rem; color: var(--accent2); }

  /* TEAM */
  .team-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; margin-top: 3rem; border: 1px solid var(--border); }
  .team-card { padding: 2rem 1.75rem; background: var(--paper); border-right: 1px solid var(--border); }
  .team-card:last-child { border-right: none; }
  .team-initial { width: 44px; height: 44px; border-radius: 50%; background: var(--accent2); color: #f5f1e8; display: flex; align-items: center; justify-content: center; font-family: var(--mono); font-size: 14px; font-weight: 500; margin-bottom: 1rem; }
  .team-name { font-family: var(--serif); font-size: 1.1rem; font-weight: 700; margin-bottom: 0.3rem; }
  .team-role { font-family: var(--mono); font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.75rem; }
  .team-bio { font-size: 0.85rem; color: var(--muted); line-height: 1.7; }

  footer { padding: 3rem 2.5rem; border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; }
  .footer-logo { font-family: var(--mono); font-size: 11px; letter-spacing: 0.1em; color: var(--muted); }
  .footer-note { font-size: 0.8rem; color: var(--muted); font-style: italic; }

  @keyframes fadeUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }
  .hero h1, .hero .hero-sub, .hero .hero-tag, .hero .hero-meta { animation: fadeUp 0.7s ease both; }
  .hero .hero-tag { animation-delay: 0.1s; }
  .hero h1 { animation-delay: 0.25s; }
  .hero .hero-sub { animation-delay: 0.4s; }
  .hero .hero-meta { animation-delay: 0.55s; }

  @media (max-width: 760px) {
    .intro-grid, .justice-grid, .team-grid, .cases-grid, .stats-row { grid-template-columns: 1fr; }
    .buyclub .kpi-grid { grid-template-columns: repeat(2, 1fr); }
    nav .nav-links { display: none; }
    .hero { padding: 6rem 1.5rem 3rem; }
    .w-section { padding: 4rem 1.5rem; }
  }
</style>
</head>
<body>

<nav>
  <span class="nav-logo">Market of Certainty</span>
  <ul class="nav-links">
    <li><a href="#overview">Overview</a></li>
    <li><a href="#viz1">524 Markets</a></li>
    <li><a href="#viz2">100% Buy Club</a></li>
    <li><a href="#viz3">Whale Problem</a></li>
