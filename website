function parseCSV(text) {
  const lines = text.trim().split('\n');
  const rows = [];
  for (let i = 1; i < lines.length; i++) {
    const parts = lines[i].split(',');
    if (parts.length < 5) continue;
    const market_id = parts[2].trim();
    const volume = parseFloat(parts[3]);
    const side = parts[4].trim();
    if (market_id && !isNaN(volume)) rows.push({ market_id, volume, side });
  }
  return rows;
}

function aggregateMarkets(rows) {
  const map = {};
  for (const r of rows) {
    if (!map[r.market_id]) map[r.market_id] = { buyVol: 0, sellVol: 0, buyTrades: 0, sellTrades: 0 };
    if (r.side === 'BUY') { map[r.market_id].buyVol += r.volume; map[r.market_id].buyTrades++; }
    else { map[r.market_id].sellVol += r.volume; map[r.market_id].sellTrades++; }
  }
  return Object.entries(map).map(([id, d]) => {
    const trades = d.buyTrades + d.sellTrades;
    const totalVol = d.buyVol + d.sellVol;
    const buyPct = totalVol > 0 ? (d.buyVol / totalVol) * 100 : 0;
    const suspicion = buyPct * (1 / Math.log2(trades + 2));
    const short = '0x' + id.slice(2, 8) + '…' + id.slice(-6);
    return { id, short, buyVol: d.buyVol, sellVol: d.sellVol, buyTrades: d.buyTrades, sellTrades: d.sellTrades, trades, totalVol, buyPct, suspicion };
  });
}

